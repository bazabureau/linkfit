    "waiver.header.subtitle": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Qeydiyyatdan əvvəl şərtləri oxu və təsdiqlə."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
