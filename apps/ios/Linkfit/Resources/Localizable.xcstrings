            "state": "translated",
            "value": "Play padel\nin Baku."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Играй в падел\nв Баку."
          }
        }
      }
    },
    "onboard.p1.kicker": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaxınındakı oyunlar"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Games near you"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Игры рядом"
          }
        }
      }
    },
    "onboard.p1.subtitle": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Yaxınında oynayan oyunçuları tap — kortunu, vaxtını və komandanı bir toxunuşla seç."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find players right around you — pick a court, a time slot, a team, all in a tap."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Найди игроков рядом — выбирай корт, время и команду в один тап."
          }
        }
      }
    },
    "onboard.p2.headline": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Səviyyənə\nuyğun oyun."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Games that\nmatch your level."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Игры под\nтвой уровень."
          }
        }
      }
    },
    "onboard.p2.kicker": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "ELO uyğunluğu"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "ELO matchmaking"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подбор по ELO"
          }
        }
      }
    },
    "onboard.p2.subtitle": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hər oyunçunun ELO reytinqi var — Linkfit səni uyğun rəqiblə qarşılaşdırır, hər oyun rəqabətli olur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Every player has an ELO rating. Linkfit pairs you with opponents at your level so every match is real competition."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У каждого игрока есть рейтинг ELO — Linkfit подбирает соперников по уровню, и каждая игра — настоящая."
          }
        }
      }
    },
    "onboard.p3.headline": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Klubları\nkəşf et."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Discover\nthe clubs."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Открой\nклубы."
          }
        }
      }
    },
    "onboard.p3.kicker": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Partnyor kortları"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Partner courts"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Партнёрские корты"
          }
        }
      }
    },
    "onboard.p3.subtitle": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Şəhər boyu partnyor kortlarda oyna, bron et və topladığın etibarla daha yaxşı klublara çıx."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Play and book across partner courts city-wide, and unlock better clubs as your reputation grows."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Играй и бронируй на партнёрских кортах по всему городу — растёт репутация, открываются лучшие клубы."
          }
        }
      }
    },
    "onboard.p4.headline": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hazırsan?"
