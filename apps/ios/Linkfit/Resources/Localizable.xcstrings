      }
    },
    "waiver.sign": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "İmzala"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подписать"
          }
        }
      }
    },
    "waiver.terms.body_1": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "İdmanda zədə riski mövcuddur. Turnirdə iştirak edərək, oyunun təbii risklərini könüllü qəbul edirsiniz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sports involve risk. By taking part you accept the ordinary risks of play."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Спорт сопряжён с риском. Участвуя, вы добровольно принимаете обычные риски игры."
          }
        }
      }
    },
    "waiver.terms.body_2": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "İdman fəaliyyəti üçün yetərincə sağlam olduğunuzu və hər hansı tibbi vəziyyət barədə həkiminizlə məsləhətləşdiyinizi təsdiq edirsiniz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You confirm that you are medically fit to take part and have spoken to a doctor about any condition that might affect play."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы подтверждаете, что физически готовы к участию и проконсультировались с врачом о любых состояниях здоровья."
          }
        }
      }
    },
    "waiver.terms.body_3": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hakimlərin və təşkilatçıların qaydalarına və qərarlarına hörmət edəcəyinizə razısınız. Qaydaların pozulması diskvalifikasiya ilə nəticələnə bilər."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You agree to follow referee and organizer rulings. Violations may result in disqualification."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы соглашаетесь подчиняться решениям судей и организаторов. Нарушения могут привести к дисквалификации."
          }
        }
      }
    },
    "waiver.terms.heading_1": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Risklərin qəbulu"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Acceptance of risk"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Принятие рисков"
          }
        }
      }
    },
    "waiver.terms.heading_2": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Tibbi hazırlıq"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Medical fitness"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Состояние здоровья"
          }
        }
      }
    },
    "waiver.terms.heading_3": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Davranış"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Conduct"
          }
        },
        "ru": {
          "stringUnit": {
