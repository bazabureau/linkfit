    "privacy.delete.confirm.message": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesabın 30 gün ərzində silinmək üçün planlaşdırılacaq. Bu müddət ərzində silməni geri qaytara bilərsən. Müddət bitdikdən sonra məlumatlar geri qaytarıla bilməz."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your account will be scheduled for deletion in 30 days. You can cancel the deletion at any time during the grace period. After that, your data can't be recovered."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аккаунт будет запланирован к удалению через 30 дней. В течение этого периода удаление можно отменить. После — данные восстановить нельзя."
          }
        }
      }
    },
