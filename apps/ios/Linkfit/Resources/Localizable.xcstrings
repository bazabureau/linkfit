    },
    "onboard.p4.subtitle": {
      "localizations": {
        "az": {
          "stringUnit": {
            "state": "translated",
            "value": "İlk oyununu indi tap. Bir dəqiqədə qoşul və korta çıx."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Find your first match now. Join in a minute and step on the court."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Найди свою первую игру. Регистрация — минута, и ты на корте."
          }
        }
      }
    },
