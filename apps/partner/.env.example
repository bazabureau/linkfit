# Local Laravel API (php artisan serve --port=8788). In prod set to https://api.linkfit.az
NEXT_PUBLIC_API_URL=http://localhost:8788
# Public Linkfit app key sent as X-Linkfit-App-Key. Must match a hash listed in
# API APP_PUBLIC_API_KEY_HASHES. Do not put INTERNAL_API_KEYS in frontend apps.
NEXT_PUBLIC_LINKFIT_APP_KEY=
