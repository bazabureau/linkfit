# Linkfit API — local dev values. Copy to .env and adjust.
# All keys are validated on boot by src/shared/config/env.ts.
# In production, `enforceProductionInvariants` will refuse to boot if
# placeholder values are left in for STRIPE_*, JWT_*, METRICS_PASSWORD,
# or CORS_ORIGINS.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Postgres (matches docker-compose.yml at repo root)
DATABASE_URL=postgres://linkfit:linkfit_dev_password@localhost:55432/linkfit

# Logging
LOG_LEVEL=debug

# CORS — comma-separated allowed origins (no wildcard in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Auth (used from Module 1 onward; safe to leave as dev defaults locally)
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars-xxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-min-32-chars-xxxx
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Rate limiting (per IP, sliding window)
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_SECONDS=60

# Stricter limit for auth endpoints (register, login)
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Feature flags (Phase 2/3 — off by default in Phase 1)
FEATURE_BOOKINGS=false

# Public origin for uploaded asset URLs (defaults to http://HOST:PORT in dev)
# PUBLIC_BASE_URL=http://localhost:3000
# PUBLIC_APP_URL=http://localhost:3000

# Upload directory for message attachments (served at /uploads/*)
# UPLOAD_DIR=/tmp/linkfit-uploads

# Stripe — placeholders are accepted in development only.
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy

# /metrics endpoint — Prometheus scraper basic-auth credentials.
# Production MUST override METRICS_PASSWORD (the default is rejected at boot).
METRICS_USER=metrics
METRICS_PASSWORD=change-me-in-production

# APNs (set all four to enable real Apple push; otherwise LoggingSender)
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# APNS_AUTH_KEY=
# APNS_USE_SANDBOX=false

# SMTP (set all four to enable real email; otherwise LoggingTransport)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=no-reply@linkfit.app

# OAuth providers
# OAUTH_APPLE_CLIENT_IDS=az.linkfit.app
# OAUTH_GOOGLE_CLIENT_IDS=

# Medical profile encryption — 32-byte key (hex-encoded) enables AES-256-GCM
# at rest. When unset, profile columns are stored as plaintext UTF-8 bytes.
# MEDICAL_ENCRYPTION_KEY=

# Sentry crash + error reporting (server-side). Leave empty to disable —
# `shared/observability/sentry.ts` short-circuits init when the DSN is
# missing so the server still boots cleanly in dev/CI. To enable, paste the
# project DSN from sentry.io → Settings → Projects → linkfit-api → Client Keys.
SENTRY_DSN=
# Optional override for the release tag attached to events. Defaults to
# `npm_package_version` (pnpm-injected at runtime). Set this in CI to the
# git SHA for finer release attribution.
# SENTRY_RELEASE=

# Product analytics (PostHog). Empty key disables server-side capture
# entirely (see shared/observability/analytics.ts) — safe to leave unset
# in dev/CI. EU customers should point POSTHOG_HOST at https://eu.posthog.com;
# self-hosted deployments at their own URL.
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
