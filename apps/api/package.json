{
  "name": "@linkfit/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file=.env dist/index.js",
    "start:prod": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest",
    "migrate:up": "node --env-file=.env node_modules/.bin/node-pg-migrate up -m migrations -j sql",
    "migrate:down": "node --env-file=.env node_modules/.bin/node-pg-migrate down -m migrations -j sql",
    "migrate:create": "node-pg-migrate create -m migrations -j sql",
    "migrate:up:prod": "node-pg-migrate up -m migrations -j sql",
    "migrate:down:prod": "node-pg-migrate down -m migrations -j sql"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.1.1",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@resvg/resvg-js": "^2.6.2",
    "@sentry/node": "^8.0.0",
    "argon2": "^0.44.0",
    "fastify": "^5.1.0",
    "fastify-type-provider-zod": "^4.0.2",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.27.4",
    "node-pg-migrate": "^7.7.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "posthog-node": "^4.0.0",
    "prom-client": "^15.1.3",
    "satori": "^0.26.0",
    "stripe": "^22.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.13.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^10.1.8",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.3.3",
    "testcontainers": "^10.13.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.5"
  }
}
