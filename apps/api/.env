# Linkfit API — local dev values. Copy to .env and adjust.
# All keys are validated on boot by src/shared/config/env.ts.

NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Postgres (matches native port 5432)
DATABASE_URL=postgres://linkfit:linkfit_dev_password@localhost:5432/linkfit

# Logging
LOG_LEVEL=debug

# CORS — comma-separated allowed origins (no wildcard in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:3200

# Auth (used from Module 1 onward; safe to leave as dev defaults locally)
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars-xxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-min-32-chars-xxxx
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Rate limiting (per IP, sliding window)
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_SECONDS=60
SIGNUP_RATE_LIMIT_PER_DAY=1000
