<?php

namespace Tests\Feature;

use App\Http\Controllers\Api\OwnerApplicationsController;
use App\Models\User;
use App\Support\ApiException;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Str;
use Tests\TestCase;

/**
 * Owner-application hardening: per-user pending guard + validation on create,
 * admin authorization on the review endpoints, the transactional approve flow
 * (creates/assigns a venue and promotes the applicant to partner), and the
 * conflict/race guards. Exercises {@see OwnerApplicationsController} directly
 * against an in-memory schema.
 */
class OwnerApplicationsHardeningTest extends TestCase
{
    private const USER_A = '00000000-0000-4000-8000-0000000d0001';

    private const USER_B = '00000000-0000-4000-8000-0000000d0002';

    private const ADMIN = '00000000-0000-4000-8000-0000000d0003';

    private const MODERATOR = '00000000-0000-4000-8000-0000000d0004';

    private const VENUE = '00000000-0000-4000-8000-0000000d0005';

    protected function setUp(): void
    {
        parent::setUp();

        config()->set('database.default', 'sqlite');
        config()->set('database.connections.sqlite.database', ':memory:');
        DB::purge('sqlite');
        DB::reconnect('sqlite');

        Schema::create('users', function ($table): void {
            $table->string('id')->primary();
            $table->string('email')->nullable();
            $table->string('display_name')->nullable();
            $table->string('photo_url')->nullable();
            $table->string('admin_role')->nullable();
            $table->text('staff_permissions')->nullable();
            $table->string('staff_title')->nullable();
            $table->string('venue_id')->nullable();
            $table->timestamp('created_at')->nullable();
            $table->timestamp('updated_at')->nullable();
            $table->timestamp('deleted_at')->nullable();
        });
        Schema::create('venues', function ($table): void {
            $table->string('id')->primary();
            $table->string('name');
            $table->text('address')->nullable();
            $table->decimal('lat', 9, 6)->nullable();
            $table->decimal('lng', 9, 6)->nullable();
            $table->string('owner_user_id')->nullable();
            $table->boolean('is_partner')->default(false);
            $table->string('phone')->nullable();
            $table->text('description')->nullable();
            $table->string('status')->nullable();
            $table->timestamp('approved_at')->nullable();
            $table->string('approved_by_user_id')->nullable();
            $table->timestamp('created_at')->nullable();
            $table->timestamp('updated_at')->nullable();
        });
        Schema::create('owner_applications', function ($table): void {
            $table->string('id')->primary();
            $table->string('user_id');
            $table->string('venue_id')->nullable();
            $table->string('venue_name');
            $table->text('venue_address');
            $table->decimal('lat', 9, 6)->nullable();
            $table->decimal('lng', 9, 6)->nullable();
            $table->string('contact_name');
            $table->string('contact_phone')->nullable();
            $table->string('contact_email');
            $table->text('message')->nullable();
            $table->string('status')->default('pending');
            $table->string('reviewed_by_user_id')->nullable();
            $table->timestamp('reviewed_at')->nullable();
            $table->text('review_note')->nullable();
            $table->timestamps();
        });
        Schema::create('audit_log', function ($table): void {
            $table->string('id')->primary();
            $table->string('actor_user_id')->nullable();
            $table->string('action');
            $table->string('entity');
            $table->string('entity_id')->nullable();
            $table->text('metadata')->nullable();
            $table->timestamp('created_at')->nullable();
        });

        DB::table('users')->insert([
            ['id' => self::USER_A, 'email' => 'a@example.com', 'display_name' => 'Player A', 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::USER_B, 'email' => 'b@example.com', 'display_name' => 'Player B', 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::ADMIN, 'email' => 'admin@example.com', 'display_name' => 'Admin', 'admin_role' => 'admin', 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::MODERATOR, 'email' => 'mod@example.com', 'display_name' => 'Mod', 'admin_role' => 'moderator', 'created_at' => now(), 'updated_at' => now()],
        ]);
    }

    protected function tearDown(): void
    {
        foreach (['audit_log', 'owner_applications', 'venues', 'users'] as $table) {
            Schema::dropIfExists($table);
        }

        parent::tearDown();
    }

    private function controller(): OwnerApplicationsController
    {
        return new OwnerApplicationsController;
    }

    private function request(string $method, array $params, string $authUserId): Request
    {
        $request = Request::create('/api/v1/owner/applications', $method, $params);
        $request->attributes->set('auth_user', User::findOrFail($authUserId));

        return $request;
    }

    private function validBody(array $overrides = []): array
    {
        return array_merge([
            'venue_name' => 'My Padel Club',
            'venue_address' => 'Baku, Nizami 1',
            'contact_name' => 'Owner Person',
            'contact_email' => 'owner@example.com',
        ], $overrides);
    }

    private function seedApplication(string $userId, array $overrides = []): string
    {
        $id = (string) Str::uuid();
        DB::table('owner_applications')->insert(array_merge([
            'id' => $id,
            'user_id' => $userId,
            'venue_id' => null,
            'venue_name' => 'Club',
            'venue_address' => 'Addr',
            'lat' => 40.4,
            'lng' => 49.8,
            'contact_name' => 'Owner',
            'contact_phone' => null,
            'contact_email' => 'owner@example.com',
            'message' => null,
            'status' => 'pending',
            'created_at' => now(),
            'updated_at' => now(),
        ], $overrides));

        return $id;
    }

    public function test_create_returns_201_pending(): void
    {
        $response = $this->controller()->create($this->request('POST', $this->validBody(), self::USER_A));

        $this->assertSame(201, $response->getStatusCode());
        $body = $response->getData(true);
        $this->assertSame(self::USER_A, $body['user_id']);
        $this->assertSame('pending', $body['status']);
        $this->assertSame(1, DB::table('owner_applications')->where('user_id', self::USER_A)->count());
    }

    public function test_create_conflict_when_pending_exists(): void
    {
        $this->controller()->create($this->request('POST', $this->validBody(), self::USER_A));
        try {
            $this->controller()->create($this->request('POST', $this->validBody(), self::USER_A));
            $this->fail('Expected a 409 for a second pending application.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
        $this->assertSame(1, DB::table('owner_applications')->where('user_id', self::USER_A)->count());
    }

    public function test_create_requires_lat_and_lng_together(): void
    {
        try {
            $this->controller()->create($this->request('POST', $this->validBody(['lat' => 40.4]), self::USER_A));
            $this->fail('Expected a 422 when lat is provided without lng.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
        }
    }

    public function test_create_404_for_unknown_venue(): void
    {
        try {
            $this->controller()->create($this->request('POST', $this->validBody(['venue_id' => (string) Str::uuid()]), self::USER_A));
            $this->fail('Expected a 404 for an unknown venue_id.');
        } catch (ApiException $e) {
            $this->assertSame(404, $e->getStatusCode());
        }
    }

    public function test_mine_only_returns_callers_applications(): void
    {
        $this->seedApplication(self::USER_A);
        $this->seedApplication(self::USER_B);

        $body = $this->controller()->mine($this->request('GET', [], self::USER_A))->getData(true);

        $this->assertCount(1, $body['items']);
        $this->assertSame(self::USER_A, $body['items'][0]['user_id']);
    }

    public function test_admin_index_requires_venues_permission(): void
    {
        try {
            $this->controller()->adminIndex($this->request('GET', [], self::USER_A));
            $this->fail('Expected a 403 for a non-admin hitting the admin index.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
    }

    public function test_approve_creates_venue_and_promotes_applicant(): void
    {
        $appId = $this->seedApplication(self::USER_A);

        $response = $this->controller()->approve($this->request('POST', [], self::ADMIN), $appId);

        $this->assertSame(200, $response->getStatusCode());
        $app = DB::table('owner_applications')->where('id', $appId)->first();
        $this->assertSame('approved', $app->status);
        $this->assertNotNull($app->venue_id);

        $venue = DB::table('venues')->where('id', $app->venue_id)->first();
        $this->assertSame(self::USER_A, $venue->owner_user_id);

        $user = DB::table('users')->where('id', self::USER_A)->first();
        $this->assertSame('partner', $user->admin_role);
        $this->assertSame($app->venue_id, $user->venue_id);

        $this->assertSame(1, DB::table('audit_log')->where('action', 'owner_application.approve')->count());
    }

    public function test_approve_conflict_when_already_reviewed(): void
    {
        $appId = $this->seedApplication(self::USER_A);
        $this->controller()->approve($this->request('POST', [], self::ADMIN), $appId);

        try {
            $this->controller()->approve($this->request('POST', [], self::ADMIN), $appId);
            $this->fail('Expected a 409 when approving an already-reviewed application.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
        $this->assertSame(1, DB::table('venues')->count());
    }

    public function test_approve_requires_lat_lng_for_new_venue(): void
    {
        $appId = $this->seedApplication(self::USER_A, ['lat' => null, 'lng' => null]);

        try {
            $this->controller()->approve($this->request('POST', [], self::ADMIN), $appId);
            $this->fail('Expected a 422 when creating a venue without coordinates.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
        }
        $this->assertSame(0, DB::table('venues')->count());
        $this->assertSame('pending', DB::table('owner_applications')->where('id', $appId)->value('status'));
    }

    public function test_moderator_cannot_assign_existing_venue(): void
    {
        DB::table('venues')->insert([
            'id' => self::VENUE, 'name' => 'Existing', 'address' => 'Addr', 'is_partner' => false,
            'created_at' => now(), 'updated_at' => now(),
        ]);
        $appId = $this->seedApplication(self::USER_A);

        try {
            $this->controller()->approve($this->request('POST', ['venue_id' => self::VENUE], self::MODERATOR), $appId);
            $this->fail('Expected a 403 when a moderator assigns an existing venue.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
    }

    public function test_approve_conflict_when_venue_owned_by_another(): void
    {
        DB::table('venues')->insert([
            'id' => self::VENUE, 'name' => 'Owned', 'address' => 'Addr', 'owner_user_id' => self::USER_B,
            'is_partner' => true, 'created_at' => now(), 'updated_at' => now(),
        ]);
        $appId = $this->seedApplication(self::USER_A);

        try {
            $this->controller()->approve($this->request('POST', ['venue_id' => self::VENUE], self::ADMIN), $appId);
            $this->fail('Expected a 409 when the venue is owned by another partner.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
        // Applicant must NOT have been promoted by the rolled-back transaction.
        $this->assertNull(DB::table('users')->where('id', self::USER_A)->value('admin_role'));
        $this->assertSame('pending', DB::table('owner_applications')->where('id', $appId)->value('status'));
    }

    public function test_reject_marks_rejected_and_audits(): void
    {
        $appId = $this->seedApplication(self::USER_A);

        $response = $this->controller()->reject($this->request('POST', ['review_note' => 'Incomplete'], self::ADMIN), $appId);

        $this->assertSame(200, $response->getStatusCode());
        $this->assertSame('rejected', DB::table('owner_applications')->where('id', $appId)->value('status'));
        $this->assertSame(1, DB::table('audit_log')->where('action', 'owner_application.reject')->count());
    }
}
