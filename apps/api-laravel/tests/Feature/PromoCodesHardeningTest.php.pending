<?php

namespace Tests\Feature;

use App\Http\Controllers\Api\PromoCodesController;
use App\Models\User;
use App\Support\ApiException;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Str;
use Tests\TestCase;

/**
 * Promo-code hardening: public validate-surface enumeration resistance, admin
 * authorization (read = revenue permission, write = platform admin),
 * mass-assignment safety, and the percent-discount ceiling — including the
 * partial-update path that resolves the effective discount against the stored
 * row. Exercises {@see PromoCodesController} directly against an in-memory schema.
 */
class PromoCodesHardeningTest extends TestCase
{
    private const ADMIN = '00000000-0000-4000-8000-0000000c0001';

    private const MODERATOR = '00000000-0000-4000-8000-0000000c0002';

    private const PLAYER = '00000000-0000-4000-8000-0000000c0003';

    protected function setUp(): void
    {
        parent::setUp();

        config()->set('database.default', 'sqlite');
        config()->set('database.connections.sqlite.database', ':memory:');
        config()->set('launch.promo_enabled', true);
        DB::purge('sqlite');
        DB::reconnect('sqlite');

        Schema::create('users', function ($table): void {
            $table->string('id')->primary();
            $table->string('email')->nullable();
            $table->string('display_name')->nullable();
            $table->string('admin_role')->nullable();
            $table->text('staff_permissions')->nullable();
            $table->string('venue_id')->nullable();
            $table->timestamp('created_at')->nullable();
            $table->timestamp('updated_at')->nullable();
            $table->timestamp('deleted_at')->nullable();
        });
        Schema::create('promo_codes', function ($table): void {
            $table->string('id')->primary();
            $table->string('code')->unique();
            $table->string('title')->nullable();
            $table->text('description')->nullable();
            $table->string('discount_type');
            $table->integer('discount_value');
            $table->string('currency')->default('AZN');
            $table->integer('min_amount_minor')->default(0);
            $table->integer('max_discount_minor')->nullable();
            $table->integer('max_redemptions')->nullable();
            $table->integer('per_user_limit')->default(1);
            $table->timestamp('starts_at')->nullable();
            $table->timestamp('ends_at')->nullable();
            $table->string('status')->default('active');
            $table->string('created_by_user_id')->nullable();
            $table->timestamps();
        });
        Schema::create('booking_promo_redemptions', function ($table): void {
            $table->string('id')->primary();
            $table->string('promo_code_id');
            $table->string('booking_id')->nullable();
            $table->string('user_id')->nullable();
            $table->integer('discount_minor')->default(0);
            $table->timestamp('created_at')->nullable();
        });
        Schema::create('bookings', function ($table): void {
            $table->string('id')->primary();
            $table->string('status')->nullable();
        });
        Schema::create('audit_log', function ($table): void {
            $table->string('id')->primary();
            $table->string('actor_user_id')->nullable();
            $table->string('action');
            $table->string('entity');
            $table->string('entity_id')->nullable();
            $table->text('metadata')->nullable();
            $table->timestamp('created_at')->nullable();
        });

        DB::table('users')->insert([
            ['id' => self::ADMIN, 'email' => 'admin@example.com', 'display_name' => 'Admin', 'admin_role' => 'admin', 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::MODERATOR, 'email' => 'mod@example.com', 'display_name' => 'Mod', 'admin_role' => 'moderator', 'staff_permissions' => json_encode(['revenue' => false]), 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::PLAYER, 'email' => 'player@example.com', 'display_name' => 'Player', 'created_at' => now(), 'updated_at' => now()],
        ]);
    }

    protected function tearDown(): void
    {
        foreach (['audit_log', 'bookings', 'booking_promo_redemptions', 'promo_codes', 'users'] as $table) {
            Schema::dropIfExists($table);
        }

        parent::tearDown();
    }

    private function controller(): PromoCodesController
    {
        return new PromoCodesController;
    }

    private function request(string $method, array $params, ?string $authUserId = null, ?string $id = null): Request
    {
        $path = '/api/v1/admin/promo-codes'.($id !== null ? '/'.$id : '');
        $request = Request::create($path, $method, $params);
        if ($authUserId !== null) {
            $request->attributes->set('auth_user', User::findOrFail($authUserId));
        }
        if ($id !== null) {
            // The controller resolves the target id via $request->route('id');
            // bind a matching route so that resolver returns it under test.
            $route = new \Illuminate\Routing\Route([$method], '/api/v1/admin/promo-codes/{id}', []);
            $route->bind($request);
            $request->setRouteResolver(fn () => $route);
        }

        return $request;
    }

    private function seedPromo(array $overrides = []): string
    {
        $id = (string) Str::uuid();
        DB::table('promo_codes')->insert(array_merge([
            'id' => $id,
            'code' => 'SAVE20',
            'discount_type' => 'percent',
            'discount_value' => 20,
            'currency' => 'AZN',
            'min_amount_minor' => 0,
            'per_user_limit' => 1,
            'status' => 'active',
            'created_at' => now(),
            'updated_at' => now(),
        ], $overrides));

        return $id;
    }

    // ---- public validate surface -------------------------------------------

    public function test_validate_applies_percent_discount(): void
    {
        $this->seedPromo(['code' => 'SAVE20', 'discount_type' => 'percent', 'discount_value' => 20]);

        $body = $this->controller()->validateCode(
            $this->request('POST', ['code' => 'save20', 'amount_minor' => 10000, 'currency' => 'AZN'])
        )->getData(true);

        $this->assertSame(2000, $body['discount_minor']);
        $this->assertSame(8000, $body['total_minor']);
        $this->assertSame('SAVE20', $body['promo']['code']);
    }

    public function test_validate_unknown_code_returns_generic_422(): void
    {
        try {
            $this->controller()->validateCode($this->request('POST', ['code' => 'NOPE', 'amount_minor' => 10000]));
            $this->fail('Expected a 422 for an unknown promo code.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
            $this->assertSame('Promo code is not valid', $e->getMessage());
        }
    }

    public function test_validate_min_amount_breach_collapses_to_generic_422(): void
    {
        $this->seedPromo(['code' => 'MIN50', 'min_amount_minor' => 5000]);

        try {
            $this->controller()->validateCode($this->request('POST', ['code' => 'MIN50', 'amount_minor' => 1000, 'currency' => 'AZN']));
            $this->fail('Expected a generic 422 when the minimum amount is not met.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
            // Must not reveal that the code exists or its minimum amount.
            $this->assertSame('Promo code is not valid', $e->getMessage());
        }
    }

    public function test_validate_per_user_limit_collapses_to_generic_422(): void
    {
        $promoId = $this->seedPromo(['code' => 'ONCE', 'per_user_limit' => 1]);
        DB::table('booking_promo_redemptions')->insert([
            'id' => (string) Str::uuid(),
            'promo_code_id' => $promoId,
            'booking_id' => (string) Str::uuid(),
            'user_id' => self::PLAYER,
            'discount_minor' => 2000,
            'created_at' => now(),
        ]);

        try {
            $this->controller()->validateCode(
                $this->request('POST', ['code' => 'ONCE', 'amount_minor' => 10000, 'currency' => 'AZN'], self::PLAYER)
            );
            $this->fail('Expected a generic 422 once the per-user limit is reached.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
            $this->assertSame('Promo code is not valid', $e->getMessage());
        }
    }

    public function test_validate_returns_404_when_promo_disabled(): void
    {
        config()->set('launch.promo_enabled', false);
        $this->seedPromo(['code' => 'SAVE20']);

        try {
            $this->controller()->validateCode($this->request('POST', ['code' => 'SAVE20', 'amount_minor' => 10000]));
            $this->fail('Expected a 404 when promo codes are disabled.');
        } catch (ApiException $e) {
            $this->assertSame(404, $e->getStatusCode());
        }
    }

    // ---- admin authorization ------------------------------------------------

    public function test_admin_index_requires_revenue_permission(): void
    {
        try {
            $this->controller()->adminIndex($this->request('GET', [], self::MODERATOR));
            $this->fail('Expected a 403 for a moderator without the revenue permission.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }

        $body = $this->controller()->adminIndex($this->request('GET', [], self::ADMIN))->getData(true);
        $this->assertArrayHasKey('items', $body);
        $this->assertArrayHasKey('pagination', $body);
    }

    public function test_admin_store_requires_platform_admin(): void
    {
        try {
            $this->controller()->adminStore($this->request('POST', [
                'code' => 'NEW10', 'discount_type' => 'percent', 'discount_value' => 10,
            ], self::MODERATOR));
            $this->fail('Expected a 403 for a non-platform-admin creating a promo.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
        $this->assertSame(0, DB::table('promo_codes')->count());
    }

    public function test_admin_store_creates_promo_and_audits(): void
    {
        $response = $this->controller()->adminStore($this->request('POST', [
            'code' => 'welcome15', 'discount_type' => 'percent', 'discount_value' => 15,
        ], self::ADMIN));

        $this->assertSame(201, $response->getStatusCode());
        $body = $response->getData(true);
        $this->assertSame('WELCOME15', $body['code']);
        $this->assertSame(self::ADMIN, $body['created_by_user_id']);
        $this->assertSame(1, DB::table('promo_codes')->where('code', 'WELCOME15')->count());
        $this->assertSame(1, DB::table('audit_log')->where('action', 'promo.create')->count());
    }

    public function test_admin_store_rejects_percent_over_100(): void
    {
        try {
            $this->controller()->adminStore($this->request('POST', [
                'code' => 'TOOBIG', 'discount_type' => 'percent', 'discount_value' => 150,
            ], self::ADMIN));
            $this->fail('Expected a 422 for a percent discount over 100.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
        }
    }

    public function test_admin_store_rejects_duplicate_code(): void
    {
        $this->seedPromo(['code' => 'DUPE']);
        try {
            $this->controller()->adminStore($this->request('POST', [
                'code' => 'dupe', 'discount_type' => 'fixed', 'discount_value' => 500,
            ], self::ADMIN));
            $this->fail('Expected a 422 for a duplicate promo code.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
        }
    }

    /**
     * Regression: flipping discount_type to "percent" on a partial update while
     * the stored discount_value is a large "fixed" amount must be rejected — the
     * effective value is resolved against the stored row, not defaulted to 0.
     */
    public function test_admin_update_flip_to_percent_keeps_value_ceiling(): void
    {
        $id = $this->seedPromo(['code' => 'FIXED', 'discount_type' => 'fixed', 'discount_value' => 5000]);

        try {
            $this->controller()->adminUpdate(
                $this->request('PATCH', ['discount_type' => 'percent'], self::ADMIN, $id),
                $id,
            );
            $this->fail('Expected a 422 when a partial flip to percent leaves a >100 value.');
        } catch (ApiException $e) {
            $this->assertSame(422, $e->getStatusCode());
            $this->assertSame('Percent discount cannot exceed 100', $e->getMessage());
        }
        // Stored row is untouched by the rejected update.
        $this->assertSame('fixed', DB::table('promo_codes')->where('id', $id)->value('discount_type'));
    }

    public function test_admin_delete_archives_promo(): void
    {
        $id = $this->seedPromo(['code' => 'GONE']);

        $body = $this->controller()->adminDelete($this->request('DELETE', [], self::ADMIN, $id), $id)->getData(true);

        $this->assertSame('archived', $body['status']);
        $this->assertSame('archived', DB::table('promo_codes')->where('id', $id)->value('status'));
    }
}
