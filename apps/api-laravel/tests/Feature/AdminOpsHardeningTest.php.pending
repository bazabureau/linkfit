<?php

namespace Tests\Feature;

use App\Http\Controllers\Api\AdminOpsController;
use App\Models\User;
use App\Support\ApiException;
use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Illuminate\Support\Facades\Schema;
use Illuminate\Support\Str;
use Tests\TestCase;

/**
 * Hardening coverage for the admin-ops slice. Exercises {@see AdminOpsController}
 * directly against an in-memory schema:
 *  - moderationUser() must never leak the credential hash / OAuth subjects
 *  - CSV exports (bookings + revenue) must neutralise spreadsheet formula
 *    injection in user-controlled columns
 *  - the destructive user-state endpoints (suspend / soft-delete / deactivate)
 *    refuse self-targeting and refuse a moderator disabling a staff account,
 *    while still working for an admin against a regular player
 */
class AdminOpsHardeningTest extends TestCase
{
    private const ADMIN = '00000000-0000-4000-8000-0000000a0001';

    private const MODERATOR = '00000000-0000-4000-8000-0000000a0002';

    private const PLAYER = '00000000-0000-4000-8000-0000000a0003';

    private const VENUE = '00000000-0000-4000-8000-0000000a0004';

    private const COURT = '00000000-0000-4000-8000-0000000a0005';

    protected function setUp(): void
    {
        parent::setUp();

        config()->set('database.default', 'sqlite');
        config()->set('database.connections.sqlite.database', ':memory:');
        DB::purge('sqlite');
        DB::reconnect('sqlite');

        Schema::create('users', function ($table): void {
            $table->string('id')->primary();
            $table->string('email')->nullable();
            $table->string('display_name')->nullable();
            $table->string('admin_role')->nullable();
            $table->text('staff_permissions')->nullable();
            $table->string('venue_id')->nullable();
            $table->text('password_hash')->nullable();
            $table->string('google_sub')->nullable();
            $table->string('apple_sub')->nullable();
            $table->timestamp('suspended_at')->nullable();
            $table->string('suspension_reason')->nullable();
            $table->string('suspended_by_user_id')->nullable();
            $table->timestamp('created_at')->nullable();
            $table->timestamp('updated_at')->nullable();
            $table->timestamp('deleted_at')->nullable();
        });
        Schema::create('audit_log', function ($table): void {
            $table->string('id')->primary();
            $table->string('actor_user_id')->nullable();
            $table->string('action');
            $table->string('entity');
            $table->string('entity_id')->nullable();
            $table->text('metadata')->nullable();
            $table->timestamp('created_at')->nullable();
        });
        Schema::create('reports', function ($table): void {
            $table->string('id')->primary();
            $table->string('reporter_user_id')->nullable();
            $table->string('target_kind')->nullable();
            $table->string('target_id')->nullable();
            $table->string('status')->nullable();
            $table->timestamp('created_at')->nullable();
        });
        Schema::create('games', function ($table): void {
            $table->string('id')->primary();
            $table->string('host_user_id')->nullable();
            $table->string('status')->nullable();
        });
        Schema::create('game_participants', function ($table): void {
            $table->string('game_id');
            $table->string('user_id');
            $table->string('status')->nullable();
        });
        Schema::create('venues', function ($table): void {
            $table->string('id')->primary();
            $table->string('name');
            $table->string('status')->nullable();
        });
        Schema::create('courts', function ($table): void {
            $table->string('id')->primary();
            $table->string('venue_id');
            $table->string('sport_id')->nullable();
            $table->string('name');
            $table->string('status')->nullable();
            $table->integer('hourly_price_minor')->default(1000);
            $table->string('currency', 3)->default('AZN');
        });
        Schema::create('bookings', function ($table): void {
            $table->string('id')->primary();
            $table->string('court_id');
            $table->string('user_id')->nullable();
            $table->timestamp('starts_at')->nullable();
            $table->integer('duration_minutes')->default(60);
            $table->integer('total_minor')->default(1000);
            $table->string('currency', 3)->default('AZN');
            $table->string('status')->nullable();
            $table->string('payment_method')->nullable();
            $table->string('customer_name')->nullable();
            $table->string('customer_email')->nullable();
            $table->timestamp('created_at')->nullable();
        });

        DB::table('users')->insert([
            ['id' => self::ADMIN, 'email' => 'admin@example.com', 'display_name' => 'Admin', 'admin_role' => 'admin', 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::MODERATOR, 'email' => 'mod@example.com', 'display_name' => 'Mod', 'admin_role' => 'moderator', 'staff_permissions' => json_encode(['users' => true, 'reports' => true]), 'created_at' => now(), 'updated_at' => now()],
            ['id' => self::PLAYER, 'email' => 'player@example.com', 'display_name' => 'Player', 'password_hash' => 'argon2id$secret-hash', 'google_sub' => 'g-12345', 'apple_sub' => 'a-67890', 'created_at' => now(), 'updated_at' => now()],
        ]);
        DB::table('venues')->insert(['id' => self::VENUE, 'name' => 'Toppadel', 'status' => 'published']);
        DB::table('courts')->insert(['id' => self::COURT, 'venue_id' => self::VENUE, 'sport_id' => 'padel-sport', 'name' => 'Court 1', 'status' => 'active', 'hourly_price_minor' => 1000, 'currency' => 'AZN']);
    }

    protected function tearDown(): void
    {
        foreach (['bookings', 'courts', 'venues', 'game_participants', 'games', 'reports', 'audit_log', 'users'] as $table) {
            Schema::dropIfExists($table);
        }

        parent::tearDown();
    }

    private function controller(): AdminOpsController
    {
        return new AdminOpsController;
    }

    private function request(string $method, array $params = [], ?string $authUserId = null): Request
    {
        $request = Request::create('/api/v1/admin', $method, $params);
        if ($authUserId !== null) {
            $request->attributes->set('auth_user', User::findOrFail($authUserId));
        }

        return $request;
    }

    // ---- moderationUser secret leak ----------------------------------------

    public function test_moderation_user_does_not_leak_credential_hash_or_oauth_subjects(): void
    {
        $body = $this->controller()->moderationUser($this->request('GET', [], self::ADMIN), self::PLAYER)->getData(true);

        $this->assertSame(self::PLAYER, $body['id']);
        $this->assertSame('Player', $body['display_name']);
        $this->assertArrayNotHasKey('password_hash', $body);
        $this->assertArrayNotHasKey('google_sub', $body);
        $this->assertArrayNotHasKey('apple_sub', $body);
        // The moderation counters still come through.
        $this->assertArrayHasKey('reports_filed_count', $body);
        $this->assertArrayHasKey('games_played_total', $body);
    }

    public function test_moderation_user_requires_staff(): void
    {
        try {
            $this->controller()->moderationUser($this->request('GET', [], self::PLAYER), self::PLAYER);
            $this->fail('Expected a 403 for a non-staff caller.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
    }

    // ---- CSV formula injection ---------------------------------------------

    public function test_export_bookings_neutralises_formula_injection(): void
    {
        $this->seedBooking(['customer_name' => '=cmd|"/c calc"!A1', 'status' => 'paid']);

        $csv = $this->controller()->exportBookings($this->request('GET', [], self::ADMIN))->getContent();

        // The dangerous "=" cell must be defanged with a leading apostrophe.
        $this->assertStringContainsString("'=cmd", $csv);
        $this->assertStringNotContainsString(',=cmd', $csv);
    }

    public function test_revenue_csv_neutralises_formula_injection(): void
    {
        DB::table('venues')->where('id', self::VENUE)->update(['name' => '@SUM(1+1)']);
        $this->seedBooking(['status' => 'paid']);

        $csv = $this->controller()->revenue($this->request('GET', ['format' => 'csv'], self::ADMIN))->getContent();

        $this->assertStringContainsString("'@SUM(1+1)", $csv);
    }

    // ---- self-lockout + staff-disable guards -------------------------------

    public function test_admin_cannot_soft_delete_their_own_account(): void
    {
        try {
            $this->controller()->softDelete($this->request('POST', [], self::ADMIN), self::ADMIN);
            $this->fail('Expected a 409 when soft-deleting your own account.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
        $this->assertNull(DB::table('users')->where('id', self::ADMIN)->value('deleted_at'));
    }

    public function test_soft_delete_unknown_user_is_404(): void
    {
        try {
            $this->controller()->softDelete($this->request('POST', [], self::ADMIN), (string) Str::uuid());
            $this->fail('Expected a 404 for an unknown user.');
        } catch (ApiException $e) {
            $this->assertSame(404, $e->getStatusCode());
        }
    }

    public function test_moderator_cannot_soft_delete_an_admin(): void
    {
        try {
            $this->controller()->softDelete($this->request('POST', [], self::MODERATOR), self::ADMIN);
            $this->fail('Expected a 403 when a moderator disables a staff account.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
        $this->assertNull(DB::table('users')->where('id', self::ADMIN)->value('deleted_at'));
    }

    public function test_admin_can_soft_delete_a_regular_player(): void
    {
        $response = $this->controller()->softDelete($this->request('POST', [], self::ADMIN), self::PLAYER);

        $this->assertSame(204, $response->getStatusCode());
        $this->assertNotNull(DB::table('users')->where('id', self::PLAYER)->value('deleted_at'));
        $this->assertSame(1, DB::table('audit_log')->where('action', 'user.soft_delete')->count());
    }

    public function test_admin_cannot_suspend_their_own_account(): void
    {
        try {
            $this->controller()->suspendUser($this->request('POST', ['reason' => 'spam'], self::ADMIN), self::ADMIN);
            $this->fail('Expected a 409 when suspending your own account.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
    }

    public function test_moderator_cannot_suspend_an_admin(): void
    {
        try {
            $this->controller()->suspendUser($this->request('POST', ['reason' => 'lockout attempt'], self::MODERATOR), self::ADMIN);
            $this->fail('Expected a 403 when a moderator suspends a staff account.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
        $this->assertNull(DB::table('users')->where('id', self::ADMIN)->value('suspended_at'));
    }

    public function test_admin_cannot_deactivate_their_own_account(): void
    {
        try {
            $this->controller()->deactivateUser($this->request('POST', [], self::ADMIN), self::ADMIN);
            $this->fail('Expected a 409 when deactivating your own account.');
        } catch (ApiException $e) {
            $this->assertSame(409, $e->getStatusCode());
        }
    }

    public function test_moderator_cannot_deactivate_an_admin(): void
    {
        try {
            $this->controller()->deactivateUser($this->request('POST', [], self::MODERATOR), self::ADMIN);
            $this->fail('Expected a 403 when a moderator deactivates a staff account.');
        } catch (ApiException $e) {
            $this->assertSame(403, $e->getStatusCode());
        }
        $this->assertNull(DB::table('users')->where('id', self::ADMIN)->value('deleted_at'));
    }

    public function test_admin_can_deactivate_a_regular_player(): void
    {
        $response = $this->controller()->deactivateUser($this->request('POST', [], self::ADMIN), self::PLAYER);

        $this->assertSame(204, $response->getStatusCode());
        $this->assertNotNull(DB::table('users')->where('id', self::PLAYER)->value('deleted_at'));
    }

    // ---- helpers -----------------------------------------------------------

    private function seedBooking(array $overrides = []): string
    {
        $id = (string) Str::uuid();
        DB::table('bookings')->insert(array_merge([
            'id' => $id,
            'court_id' => self::COURT,
            'user_id' => self::PLAYER,
            'starts_at' => now()->addDay(),
            'duration_minutes' => 60,
            'total_minor' => 1000,
            'currency' => 'AZN',
            'status' => 'paid',
            'payment_method' => 'onsite',
            'created_at' => now(),
        ], $overrides));

        return $id;
    }
}
