APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=linkfit
DB_USERNAME=linkfit
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

HORIZON_NAME=linkfit
HORIZON_PATH=horizon
HEALTH_NOTIFICATIONS_ENABLED=false
HEALTH_TO_ADDRESS=
HEALTH_SECRET_TOKEN=
HEALTH_CACHE_STORE=
HEALTH_CHECK_HORIZON=false
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
LINKFIT_WEB_URL="${APP_URL}"
LINKFIT_WEB_LOCALE=az
LINKFIT_LOGO_URL="${APP_URL}/brand/logolinkfit-dark.png"
LINKFIT_ADMIN_URL="${APP_URL}/admin"
LINKFIT_OWNER_URL="${APP_URL}/owner"
LINKFIT_SUPPORT_EMAIL=support@linkfit.az
LINKFIT_LATEST_VERSION=1.0.0
LINKFIT_IOS_LATEST_BUILD=13
LINKFIT_IOS_MIN_SUPPORTED_BUILD=1
LINKFIT_IOS_FORCE_UPDATE=false
LINKFIT_IOS_RELEASE_NOTES_URL=

STRIPE_PUBLISHABLE_KEY=
APPLE_PAY_MERCHANT_ID=

# Membership / premium access. During launch, every user receives effective
# Premium/full access without payment. Keep public subscriptions and payments
# private/off until a provider is selected and the billing flow is ready.
FREE_TRIAL_DAYS=50
GLOBAL_FULL_ACCESS_UNTIL=2026-08-09T23:59:59Z
LAUNCH_START_AT=2026-06-21T00:00:00Z
LAUNCH_END_AT=2026-08-09T23:59:59Z
LAUNCH_WINDOW_DAYS=50
MONETIZATION_ENABLED=false
PREMIUM_UNLOCKED_FOR_ALL=true
BOOKING_FEE_ENABLED=false
BOOKING_SERVICE_FEE_MINOR=0
ONLINE_PAYMENT_ENABLED=false
REFERRAL_ENABLED=true
PROMO_ENABLED=true
LAUNCH_FREE_CANCELLATION_ENABLED=true
LAUNCH_TARGET_ACTIVE_PLAYERS=500
LAUNCH_TARGET_BOOKINGS=300
LAUNCH_TARGET_COURT_FILL_RATE_PCT=35
FREE_GAMES_PER_MONTH=30
FREE_BOOKINGS_PER_MONTH=30
MEMBERSHIP_CURRENCY=AZN
PREMIUM_PRICE_MINOR=0
MEMBERSHIP_PUBLIC_SUBSCRIPTIONS_ENABLED=false
MEMBERSHIP_PAYMENTS_ENABLED=false
MEMBERSHIP_PAYMENT_PROVIDER=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# MUST be replaced in production with strong, unique random values
# (e.g. `openssl rand -hex 48`). The app refuses to boot in production if these
# are left as the dev placeholder — a known secret lets anyone forge tokens.
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars-xxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-min-32-chars-xxxx
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# API client key gate. Public app keys are optional defense-in-depth for
# identifying official builds; they are visible to browser/mobile clients and
# must not be treated as secrets or user authentication. Most production
# deployments should leave REQUIRE_API_KEY=false and rely on JWT auth, backend
# authorization, origin checks, rate limits, WAF, and abuse detection. If the
# public gate is enabled, store only SHA-256 hashes in *_HASHES in production
# and leave plaintext key variables empty. INTERNAL keys are private
# server-to-server secrets and must never be shipped to browser/mobile apps.
REQUIRE_API_KEY=false
APP_PUBLIC_API_KEYS=
APP_PUBLIC_API_KEY_HASHES=
INTERNAL_API_KEYS=
INTERNAL_API_KEY_HASHES=
# API abuse controls. Buckets are layered by real IP and JWT/access token; if
# the optional public app-key gate is enabled, app-key fingerprint buckets are
# layered in too. Discovery is intentionally tighter because it exposes
# browse/search surfaces; write-action protects booking/game/message mutations.
API_RATE_LIMIT_PER_MINUTE=600
API_IP_RATE_LIMIT_PER_MINUTE=300
API_APP_KEY_RATE_LIMIT_PER_MINUTE=1200
API_PUBLIC_DISCOVERY_RATE_LIMIT_PER_MINUTE=120
API_PUBLIC_DISCOVERY_IP_RATE_LIMIT_PER_MINUTE=60
API_PUBLIC_DISCOVERY_APP_KEY_RATE_LIMIT_PER_MINUTE=240
API_WRITE_RATE_LIMIT_PER_MINUTE=60
API_WRITE_IP_RATE_LIMIT_PER_MINUTE=40
API_WRITE_APP_KEY_RATE_LIMIT_PER_MINUTE=180
# Browser defense-in-depth. Production should only list Linkfit-owned
# web/admin/owner origins; native apps normally send no Origin.
CORS_ALLOWED_ORIGINS=https://linkfit.az,https://www.linkfit.az,https://admin.linkfit.az,https://owner.linkfit.az

# Comma-separated CIDRs of trusted reverse proxies (nginx + your CDN/Cloudflare
# edge). Leave blank to use the built-in loopback + Cloudflare defaults so
# $request->ip() resolves the real, non-spoofable client IP.
TRUSTED_PROXIES=
# Google Sign-In: the OAuth client id(s) whose tokens we accept (aud check).
# Comma-separate iOS + web + Android ids in GOOGLE_CLIENT_IDS if more than one.
GOOGLE_CLIENT_ID=
# Defaults to the app's server + iOS OAuth client ids in config/services.php, so
# Google sign-in works without setting this. Override to change the accepted set.
GOOGLE_CLIENT_IDS=655337821050-mn0csu1bml6bbps9egumdsgr2akddnlp.apps.googleusercontent.com,655337821050-pi74ppu4gjv7b0gs0v417djtndrl7nt2.apps.googleusercontent.com
# Sign in with Apple: the token audience to accept. Native iOS tokens carry
# aud = the app bundle id, so this defaults to az.linkfit.app in config even if
# left blank here. Set/extend (e.g. add a web Service ID) via APPLE_CLIENT_IDS.
APPLE_CLIENT_ID=az.linkfit.app
APPLE_CLIENT_IDS=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=false
# Android push (Firebase Cloud Messaging HTTP v1). Path to a Google
# service-account JSON key with the Firebase Cloud Messaging API enabled.
# Leave empty to disable Android delivery (iOS/APNs is unaffected).
FCM_CREDENTIALS_PATH=
# Optional — defaults to project_id from the service-account JSON.
FCM_PROJECT_ID=
