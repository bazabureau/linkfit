APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=linkfit
DB_USERNAME=linkfit
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

HORIZON_NAME=linkfit
HORIZON_PATH=horizon
HEALTH_NOTIFICATIONS_ENABLED=false
HEALTH_TO_ADDRESS=
HEALTH_SECRET_TOKEN=
HEALTH_CACHE_STORE=
HEALTH_CHECK_HORIZON=false
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
LINKFIT_WEB_URL="${APP_URL}"
LINKFIT_WEB_LOCALE=az
LINKFIT_LOGO_URL="${APP_URL}/brand/logolinkfit-dark.png"
LINKFIT_ADMIN_URL="${APP_URL}/admin"
LINKFIT_OWNER_URL="${APP_URL}/owner"
LINKFIT_SUPPORT_EMAIL=support@linkfit.az
LINKFIT_LATEST_VERSION=1.0.0
LINKFIT_IOS_LATEST_BUILD=13
LINKFIT_IOS_MIN_SUPPORTED_BUILD=1
LINKFIT_IOS_FORCE_UPDATE=false
LINKFIT_IOS_RELEASE_NOTES_URL=

STRIPE_PUBLISHABLE_KEY=
APPLE_PAY_MERCHANT_ID=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# MUST be replaced in production with strong, unique random values
# (e.g. `openssl rand -hex 48`). The app refuses to boot in production if these
# are left as the dev placeholder — a known secret lets anyone forge tokens.
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod-min-32-chars-xxxxx
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod-min-32-chars-xxxx
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Optional API client key gate. APP_PUBLIC_API_KEYS identifies official
# web/mobile builds; it is visible to clients and is not user authentication.
# INTERNAL_API_KEYS is only for private server-to-server jobs and must never be
# shipped to browser/mobile apps.
REQUIRE_API_KEY=false
APP_PUBLIC_API_KEYS=
INTERNAL_API_KEYS=

# Comma-separated CIDRs of trusted reverse proxies (nginx + your CDN/Cloudflare
# edge). Leave blank to use the built-in loopback + Cloudflare defaults so
# $request->ip() resolves the real, non-spoofable client IP.
TRUSTED_PROXIES=
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=false
# Android push (Firebase Cloud Messaging HTTP v1). Path to a Google
# service-account JSON key with the Firebase Cloud Messaging API enabled.
# Leave empty to disable Android delivery (iOS/APNs is unaffected).
FCM_CREDENTIALS_PATH=
# Optional — defaults to project_id from the service-account JSON.
FCM_PROJECT_ID=
