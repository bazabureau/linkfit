# Linkfit API production env template.
# Copy to `.env.production` on the deployment host and fill every blank value.
# `.env.production` is gitignored; do not commit real secrets.

# Postgres container
POSTGRES_USER=linkfit
POSTGRES_PASSWORD=
POSTGRES_DB=linkfit

# Public origins
CORS_ORIGINS=https://linkfit.app,https://www.linkfit.app
PUBLIC_BASE_URL=https://api.linkfit.app
PUBLIC_APP_URL=https://linkfit.app

# Auth secrets, each at least 32 chars and not dev-prefixed.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# API client key gate. APP_PUBLIC_API_KEYS identifies official web/mobile
# clients and is safe only as an abuse-reduction layer, not as user auth.
# INTERNAL_API_KEYS is private server-to-server only.
REQUIRE_API_KEY=false
APP_PUBLIC_API_KEYS=
INTERNAL_API_KEYS=

# Runtime limits
LOG_LEVEL=info
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
FEATURE_BOOKINGS=true

# Prometheus /metrics basic auth
METRICS_USER=metrics
METRICS_PASSWORD=

# Stripe live credentials
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MEMBERSHIP_PLUS_PRICE_ID=
STRIPE_MEMBERSHIP_PREMIUM_PRICE_ID=

# APNs production credentials. APNS_AUTH_KEY may contain literal \n escapes.
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=az.linkfit.app
APNS_AUTH_KEY=
APNS_USE_SANDBOX=false

# SMTP for email verification and password reset.
# Gmail Workspace SMTP works here; use an app password or SMTP relay credential.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@linkfit.app

# OAuth accepted audiences.
OAUTH_APPLE_CLIENT_IDS=az.linkfit.app
OAUTH_GOOGLE_CLIENT_IDS=655337821050-pi74ppu4gjv7b0gs0v417djtndrl7nt2.apps.googleusercontent.com

# 32-byte key, base64 or hex encoded.
MEDICAL_ENCRYPTION_KEY=

# Optional observability
SENTRY_DSN=
SENTRY_RELEASE=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
