# Linkfit Laravel API production env template.
# Copy to `.env.production` on the deployment host and fill every blank value.
# `.env.production` is gitignored; do not commit real secrets.

APP_NAME=Linkfit
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.linkfit.az
APP_WEB_URL=https://linkfit.az
APP_LOCALE=az
APP_FALLBACK_LOCALE=en

# Postgres container / Laravel database connection
POSTGRES_USER=linkfit
POSTGRES_PASSWORD=
POSTGRES_DB=linkfit
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=linkfit
DB_USERNAME=linkfit
DB_PASSWORD=

# Runtime stores. The compose skeleton uses database-backed stores by default.
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

# Browser origins allowed to call the API.
CORS_ALLOWED_ORIGINS=https://linkfit.az,https://www.linkfit.az,https://admin.linkfit.az,https://owner.linkfit.az
TRUSTED_PROXIES=

# JWT secrets. Use strong random values and keep JWT_ACCESS_SECRET stable
# across deployments so existing sessions are not invalidated unnecessarily.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30

# Optional API client key gate. Public app keys identify official builds only;
# they are not a replacement for user JWT auth.
REQUIRE_API_KEY=false
APP_PUBLIC_API_KEYS=
APP_PUBLIC_API_KEY_HASHES=
INTERNAL_API_KEYS=
INTERNAL_API_KEY_HASHES=

# Rate limits
API_RATE_LIMIT_PER_MINUTE=600
API_IP_RATE_LIMIT_PER_MINUTE=300
API_APP_KEY_RATE_LIMIT_PER_MINUTE=1200
API_PUBLIC_DISCOVERY_RATE_LIMIT_PER_MINUTE=120
API_PUBLIC_DISCOVERY_IP_RATE_LIMIT_PER_MINUTE=60
API_PUBLIC_DISCOVERY_APP_KEY_RATE_LIMIT_PER_MINUTE=240
API_WRITE_RATE_LIMIT_PER_MINUTE=60
API_WRITE_IP_RATE_LIMIT_PER_MINUTE=40
API_WRITE_APP_KEY_RATE_LIMIT_PER_MINUTE=180

# Product links and app metadata
LINKFIT_WEB_URL=https://linkfit.az
LINKFIT_WEB_LOCALE=az
LINKFIT_LOGO_URL=https://linkfit.az/brand/logolinkfit-dark.png
LINKFIT_ADMIN_URL=https://admin.linkfit.az
LINKFIT_OWNER_URL=https://owner.linkfit.az
LINKFIT_SUPPORT_EMAIL=support@linkfit.az
LINKFIT_LATEST_VERSION=1.0.0
LINKFIT_IOS_LATEST_BUILD=13
LINKFIT_IOS_MIN_SUPPORTED_BUILD=1
LINKFIT_IOS_FORCE_UPDATE=false
LINKFIT_IOS_RELEASE_NOTES_URL=

# Membership / premium access
FREE_TRIAL_DAYS=50
GLOBAL_FULL_ACCESS_UNTIL=
FREE_GAMES_PER_MONTH=30
FREE_BOOKINGS_PER_MONTH=30
MEMBERSHIP_CURRENCY=AZN
PREMIUM_PRICE_MINOR=0
MEMBERSHIP_PUBLIC_SUBSCRIPTIONS_ENABLED=false
MEMBERSHIP_PAYMENTS_ENABLED=false
MEMBERSHIP_PAYMENT_PROVIDER=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@linkfit.az
MAIL_FROM_NAME=Linkfit

# OAuth / platform credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
APPLE_CLIENT_ID=az.linkfit.app
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=az.linkfit.app
APNS_PRIVATE_KEY_PATH=
APNS_PRODUCTION=true
FCM_CREDENTIALS_PATH=
FCM_PROJECT_ID=

# Payments currently use Laravel membership/payment feature flags above.
STRIPE_PUBLISHABLE_KEY=
APPLE_PAY_MERCHANT_ID=

# Object storage; leave empty for local public disk.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
MEDIA_DISK=

# Observability
LOG_CHANNEL=stack
LOG_LEVEL=info
SENTRY_LARAVEL_DSN=
SENTRY_RELEASE=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_SEND_DEFAULT_PII=false
